{
  "name": "@fieldos/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --env-file=../../.env --import tsx src/index.ts",
    "lint": "eslint . --max-warnings=0",
    "start": "node --env-file=../../.env dist/index.js",
    "start:railway": "tsx src/index.ts",
    "test": "vitest run src --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fieldos/auth": "workspace:*",
    "@fieldos/baileys-whatsapp": "workspace:*",
    "@fieldos/db": "workspace:*",
    "@fieldos/ai": "workspace:*",
    "@fieldos/messaging": "workspace:*",
    "@fieldos/shared": "workspace:*",
    "fastify": "^5.6.2",
    "ioredis": "^5.8.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
