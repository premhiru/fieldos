{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm --filter @fieldos/db db:generate && pnpm --filter @fieldos/api build"
  },
  "deploy": {
    "startCommand": "pnpm deploy:migrate && pnpm api:start:railway",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
