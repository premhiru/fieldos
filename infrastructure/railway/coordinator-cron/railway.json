{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "cronSchedule": "0 */4 * * *",
    "startCommand": "curl --fail-with-body --silent --show-error -X POST \"$COORDINATOR_SCAN_URL/internal/coordinator-scan\" -H \"Authorization: Bearer $CRON_SECRET\"",
    "restartPolicyType": "NEVER"
  }
}
