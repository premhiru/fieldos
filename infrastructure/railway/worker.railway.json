{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @fieldos/db db:generate && pnpm --filter @fieldos/worker build"
  },
  "deploy": {
    "startCommand": "pnpm worker:start:railway",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
