generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                       String                    @id @default(cuid())
  name                     String
  slug                     String                    @unique
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  aiMessageClassifications AIMessageClassification[]
  actionItems              ActionItem[]
  conversations            Conversation[]
  events                   Event[]
  milestones               Milestone[]
  memberships              Membership[]
  processingJobs           ProcessingJob[]
  projects                 Project[]
  searchDocuments          SearchDocument[]
  whatsAppAccounts         WhatsAppAccount[]
  whatsAppChatMapping      WhatsAppChatMapping[]
}

model User {
  id                            String                @id @default(cuid())
  email                         String                @unique
  name                          String
  passwordHash                  String
  createdAt                     DateTime              @default(now())
  updatedAt                     DateTime              @updatedAt
  activatedWhatsAppChatMappings WhatsAppChatMapping[]
  acceptedActionItems           ActionItem[]          @relation("ActionItemAcceptedBy")
  assignedActionItems           ActionItem[]          @relation("ActionItemAssignedTo")
  ignoredActionItems            ActionItem[]          @relation("ActionItemIgnoredBy")
  memberships                   Membership[]
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(MEMBER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Project {
  id                       String                    @id @default(cuid())
  organizationId           String
  name                     String
  code                     String
  status                   ProjectStatus             @default(ACTIVE)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  aiMessageClassifications AIMessageClassification[]
  actionItems              ActionItem[]
  conversations            Conversation[]
  events                   Event[]
  milestones               Milestone[]
  organization             Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  searchDocuments          SearchDocument[]
  suggestedActionItems     ActionItem[]              @relation("ActionItemSuggestedProject")
  whatsAppChatMapping      WhatsAppChatMapping[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model Conversation {
  id              String               @id @default(cuid())
  organizationId  String
  projectId       String?
  externalId      String
  channel         Channel
  title           String
  isGroup         Boolean              @default(false)
  lastMessageAt   DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  attachments     Attachment[]
  messages        Message[]
  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  participants    Participant[]
  project         Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  whatsAppMapping WhatsAppChatMapping?

  @@unique([organizationId, channel, externalId])
  @@index([organizationId, updatedAt])
  @@index([projectId])
}

model Participant {
  id                 String       @id @default(cuid())
  conversationId     String
  displayName        String
  externalIdentifier String
  role               String
  createdAt          DateTime     @default(now())
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentMessages       Message[]

  @@unique([conversationId, externalIdentifier])
  @@index([conversationId])
}

model Message {
  id                  String                   @id @default(cuid())
  conversationId      String
  senderParticipantId String
  direction           MessageDirection
  type                MessageType
  body                String?
  externalMessageId   String?
  processingStatus    MessageProcessingStatus @default(RECEIVED)
  occurredAt          DateTime
  createdAt           DateTime                 @default(now())
  aiClassification    AIMessageClassification?
  actionItems         ActionItem[]
  attachments         Attachment[]
  conversation        Conversation             @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderParticipant   Participant              @relation(fields: [senderParticipantId], references: [id], onDelete: Restrict)

  @@unique([conversationId, externalMessageId])
  @@index([conversationId, occurredAt])
  @@index([processingStatus, createdAt])
  @@index([senderParticipantId])
}

model Attachment {
  id             String       @id @default(cuid())
  messageId      String
  conversationId String
  filename       String
  mimeType       String
  storageKey     String
  size           Int
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([messageId])
}

model AIMessageClassification {
  id               String                 @id @default(cuid())
  organizationId   String
  projectId        String?
  messageId        String                 @unique
  category         AIMessageCategory?
  summary          String?
  location         String?
  actionRequired   Boolean                @default(false)
  confidence       Float?
  reasoningSummary String?
  status           AIClassificationStatus @default(PENDING)
  errorMessage     String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  actionItems      ActionItem[]
  message          Message                @relation(fields: [messageId], references: [id], onDelete: Cascade)
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([projectId, createdAt])
  @@index([status, createdAt])
}

model ActionItem {
  id                 String                   @id @default(cuid())
  organizationId     String
  projectId          String?
  messageId          String
  classificationId   String?
  suggestedProjectId String?
  type               ActionItemType           @default(FOLLOW_UP)
  priority           ActionItemPriority       @default(MEDIUM)
  title              String
  description        String?
  confidence         Float?
  status             ActionItemStatus         @default(PENDING)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  acceptedAt         DateTime?
  acceptedByUserId   String?
  assignedToUserId   String?
  completedAt        DateTime?
  ignoredAt          DateTime?
  ignoredByUserId    String?
  acceptedByUser     User?                    @relation("ActionItemAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  assignedToUser     User?                    @relation("ActionItemAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  classification     AIMessageClassification? @relation(fields: [classificationId], references: [id], onDelete: Cascade)
  ignoredByUser      User?                    @relation("ActionItemIgnoredBy", fields: [ignoredByUserId], references: [id], onDelete: SetNull)
  message            Message                  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project            Project?                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  suggestedProject   Project?                 @relation("ActionItemSuggestedProject", fields: [suggestedProjectId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt])
  @@index([organizationId, priority, status])
  @@index([organizationId, type, status])
  @@index([projectId, status, createdAt])
  @@index([suggestedProjectId, status, createdAt])
  @@index([assignedToUserId, status, priority])
  @@index([messageId])
  @@index([classificationId])
  @@index([acceptedByUserId])
  @@index([ignoredByUserId])
}

model Milestone {
  id             String          @id @default(cuid())
  organizationId String
  projectId      String
  title          String
  dueDate        DateTime
  status         MilestoneStatus @default(UPCOMING)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId, dueDate])
  @@index([projectId, dueDate])
  @@index([status, dueDate])
}

model Event {
  id             String          @id @default(cuid())
  organizationId String
  projectId      String?
  sourceType     EventSourceType
  sourceId       String
  eventType      String
  title          String
  description    String?
  occurredAt     DateTime
  createdAt      DateTime        @default(now())
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId, occurredAt])
  @@index([projectId, occurredAt])
  @@index([sourceType, sourceId])
}

model SearchDocument {
  id             String                   @id @default(cuid())
  organizationId String
  projectId      String?
  sourceType     SearchDocumentSourceType
  sourceId       String
  title          String
  content        String
  metadata       Json?
  occurredAt     DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([sourceType, sourceId])
  @@index([organizationId, createdAt])
  @@index([organizationId, projectId, createdAt])
  @@index([organizationId, sourceType, createdAt])
  @@index([projectId, createdAt])
}

model ProcessingJob {
  id             String              @id @default(cuid())
  organizationId String
  projectId      String?
  type           ProcessingJobType
  status         ProcessingJobStatus @default(PENDING)
  sourceType     String
  sourceId       String
  attempts       Int                 @default(0)
  maxAttempts    Int                 @default(3)
  errorMessage   String?
  correlationId  String
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([type, sourceType, sourceId])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, type, status])
  @@index([projectId, status, createdAt])
  @@index([status, createdAt])
}

model WorkerHeartbeat {
  id              String       @id @default(cuid())
  workerName      String       @unique
  version         String
  status          WorkerStatus @default(STARTING)
  lastHeartbeatAt DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status, lastHeartbeatAt])
}

model WhatsAppAccount {
  id                 String                @id @default(cuid())
  organizationId     String
  displayName        String
  phoneNumber        String?
  connectorType      WhatsAppConnectorType @default(BAILEYS)
  status             WhatsAppAccountStatus @default(PENDING_QR)
  sessionKey         String
  lastConnectedAt    DateTime?
  lastDisconnectedAt DateTime?
  lastMessageAt      DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  chatMappings       WhatsAppChatMapping[]
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([sessionKey])
  @@index([organizationId])
}

model WhatsAppChatMapping {
  id                String                    @id @default(cuid())
  organizationId    String
  whatsappAccountId String
  conversationId    String?
  projectId         String?
  jid               String
  chatName          String?
  isGroup           Boolean                   @default(false)
  status            WhatsAppChatMappingStatus @default(DISCOVERED)
  activatedAt       DateTime?
  activatedByUserId String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  activatedByUser   User?                     @relation(fields: [activatedByUserId], references: [id], onDelete: SetNull)
  conversation      Conversation?             @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  organization      Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project?                  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  whatsappAccount   WhatsAppAccount           @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)

  @@unique([whatsappAccountId, jid])
  @@unique([conversationId])
  @@index([activatedByUserId])
  @@index([organizationId])
  @@index([projectId])
  @@index([status])
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum Channel {
  WHATSAPP
  EMAIL
  SLACK
  TEAMS
  SMS
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  VOICE
  VIDEO
  SYSTEM
}

enum MessageProcessingStatus {
  RECEIVED
  MEDIA_PENDING
  MEDIA_COMPLETE
  TRANSCRIPTION_PENDING
  TRANSCRIPTION_COMPLETE
  SEARCH_PENDING
  SEARCH_COMPLETE
  AI_PENDING
  AI_COMPLETE
  FAILED
}

enum ProcessingJobType {
  SEARCH_INDEX
  AI_CLASSIFICATION
  VOICE_TRANSCRIPTION
  MEDIA_DOWNLOAD
}

enum ProcessingJobStatus {
  PENDING
  RUNNING
  FAILED
  COMPLETED
}

enum WorkerStatus {
  ONLINE
  OFFLINE
  STARTING
  STOPPING
}

enum WhatsAppConnectorType {
  BAILEYS
  META_CLOUD
}

enum WhatsAppAccountStatus {
  PENDING_QR
  CONNECTING
  CONNECTED
  DISCONNECTED
  ERROR
}

enum WhatsAppChatMappingStatus {
  DISCOVERED
  ACTIVE
  IGNORED
  ARCHIVED
}

enum AIMessageCategory {
  PROGRESS_UPDATE
  DEFECT
  DELAY
  SAFETY_ISSUE
  DELIVERY
  INSPECTION_REQUEST
  CLIENT_APPROVAL
  VARIATION_ORDER
  RFI
  MATERIAL_ISSUE
  MANPOWER_ISSUE
  GENERAL_NOTE
  UNKNOWN
}

enum AIClassificationStatus {
  PENDING
  COMPLETED
  FAILED
  NEEDS_REVIEW
}

enum ActionItemStatus {
  PENDING
  ACCEPTED
  COMPLETED
  IGNORED
  CONVERTED
}

enum ActionItemType {
  FOLLOW_UP
  PROJECT_SUGGESTION
}

enum ActionItemPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EventSourceType {
  MESSAGE
  ACTION_ITEM
  REPORT
  SYSTEM
}

enum MilestoneStatus {
  UPCOMING
  DUE_SOON
  OVERDUE
  COMPLETED
}

enum SearchDocumentSourceType {
  PROJECT
  MESSAGE
  TIMELINE_EVENT
  ACTION_ITEM
  AI_CLASSIFICATION
}
