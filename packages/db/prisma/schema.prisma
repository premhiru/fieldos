generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                       String                    @id @default(cuid())
  name                     String
  slug                     String                    @unique
  isDemo                   Boolean                   @default(false)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  aiMessageClassifications AIMessageClassification[]
  actionItems              ActionItem[]
  coordinatorRuns          CoordinatorRun[]
  conversations            Conversation[]
  events                   Event[]
  feedback                 UserFeedback[]
  analyticsEvents          ProductAnalyticsEvent[]
  milestones               Milestone[]
  memberships              Membership[]
  teamInvitations          TeamInvitation[]
  notifications            UserNotification[]
  photoAnalyses            PhotoAnalysis[]
  processingJobs           ProcessingJob[]
  projectStates            ProjectState[]
  projectReports           ProjectReport[]
  projects                 Project[]
  recommendations          Recommendation[]
  searchDocuments          SearchDocument[]
  whatsAppAccounts         WhatsAppAccount[]
  whatsAppChatMapping      WhatsAppChatMapping[]
  whatsAppDrafts           WhatsAppDraft[]
}

model User {
  id                            String                  @id @default(cuid())
  email                         String                  @unique
  name                          String
  passwordHash                  String
  sessionVersion                Int                     @default(0)
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt
  activatedWhatsAppChatMappings WhatsAppChatMapping[]
  acceptedActionItems           ActionItem[]            @relation("ActionItemAcceptedBy")
  assignedActionItems           ActionItem[]            @relation("ActionItemAssignedTo")
  analyticsEvents               ProductAnalyticsEvent[]
  feedback                      UserFeedback[]
  ignoredActionItems            ActionItem[]            @relation("ActionItemIgnoredBy")
  createdMilestones             Milestone[]             @relation("MilestoneCreatedBy")
  memberships                   Membership[]
  acceptedTeamInvitations       TeamInvitation[]        @relation("TeamInvitationAcceptedBy")
  sentTeamInvitations           TeamInvitation[]        @relation("TeamInvitationInvitedBy")
  notifications                 UserNotification[]
  passwordResetTokens           PasswordResetToken[]
  approvedRecommendations       Recommendation[]        @relation("RecommendationApprovedBy")
  dismissedRecommendations      Recommendation[]        @relation("RecommendationDismissedBy")
  createdWhatsAppDrafts         WhatsAppDraft[]         @relation("WhatsAppDraftCreatedBy")
  approvedWhatsAppDrafts        WhatsAppDraft[]         @relation("WhatsAppDraftApprovedBy")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model Membership {
  id             String          @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole  @default(MEMBER)
  allProjects    Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectAccess  ProjectAccess[]

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model TeamInvitation {
  id               String                  @id @default(cuid())
  organizationId   String
  email            String
  role             MembershipRole
  tokenHash        String                  @unique
  expiresAt        DateTime
  acceptedAt       DateTime?
  revokedAt        DateTime?
  invitedByUserId  String
  acceptedByUserId String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy        User                    @relation("TeamInvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  acceptedBy       User?                   @relation("TeamInvitationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  projects         TeamInvitationProject[]

  @@index([organizationId, createdAt])
  @@index([email, organizationId])
  @@index([expiresAt])
}

model TeamInvitationProject {
  invitationId String
  projectId    String
  invitation   TeamInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([invitationId, projectId])
  @@index([projectId])
}

model ProjectAccess {
  id           String     @id @default(cuid())
  membershipId String
  projectId    String
  createdAt    DateTime   @default(now())
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([membershipId, projectId])
  @@index([projectId])
}

model Project {
  id                       String                    @id @default(cuid())
  organizationId           String
  name                     String
  code                     String
  status                   ProjectStatus             @default(ACTIVE)
  timezone                 String                    @default("UTC")
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  aiMessageClassifications AIMessageClassification[]
  actionItems              ActionItem[]
  coordinatorRuns          CoordinatorRun[]
  conversations            Conversation[]
  events                   Event[]
  milestones               Milestone[]
  organization             Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  photoAnalyses            PhotoAnalysis[]
  projectState             ProjectState?
  projectReports           ProjectReport[]
  projectAccess            ProjectAccess[]
  recommendations          Recommendation[]
  searchDocuments          SearchDocument[]
  suggestedActionItems     ActionItem[]              @relation("ActionItemSuggestedProject")
  teamInvitationProjects   TeamInvitationProject[]
  whatsAppChatMapping      WhatsAppChatMapping[]
  whatsAppDrafts           WhatsAppDraft[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model Conversation {
  id              String               @id @default(cuid())
  organizationId  String
  projectId       String?
  externalId      String
  channel         Channel
  title           String
  isGroup         Boolean              @default(false)
  lastMessageAt   DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  attachments     Attachment[]
  messages        Message[]
  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  photoAnalyses   PhotoAnalysis[]
  participants    Participant[]
  project         Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  whatsAppMapping WhatsAppChatMapping?
  whatsAppDrafts  WhatsAppDraft[]

  @@unique([organizationId, channel, externalId])
  @@index([organizationId, updatedAt])
  @@index([projectId])
}

model Participant {
  id                 String       @id @default(cuid())
  conversationId     String
  displayName        String
  externalIdentifier String
  role               String
  createdAt          DateTime     @default(now())
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentMessages       Message[]

  @@unique([conversationId, externalIdentifier])
  @@index([conversationId])
}

model Message {
  id                  String                   @id @default(cuid())
  conversationId      String
  senderParticipantId String
  direction           MessageDirection
  type                MessageType
  body                String?
  externalMessageId   String?
  processingStatus    MessageProcessingStatus  @default(RECEIVED)
  occurredAt          DateTime
  createdAt           DateTime                 @default(now())
  aiClassification    AIMessageClassification?
  actionItems         ActionItem[]
  attachments         Attachment[]
  conversation        Conversation             @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  photoAnalyses       PhotoAnalysis[]
  sourceMilestones    Milestone[]
  senderParticipant   Participant              @relation(fields: [senderParticipantId], references: [id], onDelete: Restrict)

  @@unique([conversationId, externalMessageId])
  @@index([conversationId, occurredAt])
  @@index([processingStatus, createdAt])
  @@index([senderParticipantId])
}

model Attachment {
  id                  String                   @id @default(cuid())
  messageId           String
  conversationId      String
  filename            String
  mimeType            String
  storageKey          String
  size                Int
  transcript          String?
  transcriptionStatus VoiceTranscriptionStatus @default(NOT_REQUIRED)
  transcriptionError  String?
  createdAt           DateTime                 @default(now())
  conversation        Conversation             @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message             Message                  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  photoAnalysis       PhotoAnalysis?

  @@index([conversationId])
  @@index([messageId])
  @@index([transcriptionStatus, createdAt])
}

model PhotoAnalysis {
  id              String       @id @default(cuid())
  evidenceId      String       @unique
  organizationId  String
  projectId       String?
  conversationId  String
  messageId       String
  provider        String
  summary         String
  detectedObjects Json
  possibleIssues  Json
  confidence      Float
  tags            Json
  createdAt       DateTime     @default(now())
  evidence        Attachment   @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message         Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([projectId, createdAt])
  @@index([messageId])
  @@index([conversationId])
}

model AIMessageClassification {
  id               String                 @id @default(cuid())
  organizationId   String
  projectId        String?
  messageId        String                 @unique
  category         AIMessageCategory?
  summary          String?
  location         String?
  actionRequired   Boolean                @default(false)
  confidence       Float?
  reasoningSummary String?
  status           AIClassificationStatus @default(PENDING)
  errorMessage     String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  actionItems      ActionItem[]
  message          Message                @relation(fields: [messageId], references: [id], onDelete: Cascade)
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([projectId, createdAt])
  @@index([status, createdAt])
}

model ActionItem {
  id                 String                   @id @default(cuid())
  organizationId     String
  projectId          String?
  messageId          String
  classificationId   String?
  suggestedProjectId String?
  type               ActionItemType           @default(FOLLOW_UP)
  priority           ActionItemPriority       @default(MEDIUM)
  title              String
  description        String?
  confidence         Float?
  status             ActionItemStatus         @default(PENDING)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  acceptedAt         DateTime?
  acceptedByUserId   String?
  assignedToUserId   String?
  completedAt        DateTime?
  ignoredAt          DateTime?
  ignoredByUserId    String?
  acceptedByUser     User?                    @relation("ActionItemAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  assignedToUser     User?                    @relation("ActionItemAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  classification     AIMessageClassification? @relation(fields: [classificationId], references: [id], onDelete: Cascade)
  ignoredByUser      User?                    @relation("ActionItemIgnoredBy", fields: [ignoredByUserId], references: [id], onDelete: SetNull)
  message            Message                  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project            Project?                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  suggestedProject   Project?                 @relation("ActionItemSuggestedProject", fields: [suggestedProjectId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt])
  @@index([organizationId, priority, status])
  @@index([organizationId, type, status])
  @@index([projectId, status, createdAt])
  @@index([suggestedProjectId, status, createdAt])
  @@index([assignedToUserId, status, priority])
  @@index([messageId])
  @@index([classificationId])
  @@index([acceptedByUserId])
  @@index([ignoredByUserId])
}

model Milestone {
  id                     String            @id @default(cuid())
  organizationId         String
  projectId              String
  title                  String
  description            String?
  status                 MilestoneStatus   @default(PLANNED)
  plannedStartDate       DateTime?
  plannedEndDate         DateTime?
  actualStartDate        DateTime?
  actualEndDate          DateTime?
  priority               MilestonePriority @default(MEDIUM)
  source                 MilestoneSource   @default(MANUAL)
  createdByUserId        String?
  sourceRecommendationId String?           @unique
  sourceMessageId        String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  createdBy              User?             @relation("MilestoneCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  organization           Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project                Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceMessage          Message?          @relation(fields: [sourceMessageId], references: [id], onDelete: SetNull)
  sourceRecommendation   Recommendation?   @relation(fields: [sourceRecommendationId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, plannedEndDate])
  @@index([projectId, status, plannedStartDate])
  @@index([projectId, status, plannedEndDate])
  @@index([createdByUserId])
  @@index([sourceMessageId])
}

model Event {
  id             String          @id @default(cuid())
  organizationId String
  projectId      String?
  sourceType     EventSourceType
  sourceId       String
  eventType      String
  title          String
  description    String?
  occurredAt     DateTime
  createdAt      DateTime        @default(now())
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId, occurredAt])
  @@index([projectId, occurredAt])
  @@index([sourceType, sourceId])
}

model SearchDocument {
  id             String                   @id @default(cuid())
  organizationId String
  projectId      String?
  sourceType     SearchDocumentSourceType
  sourceId       String
  title          String
  content        String
  metadata       Json?
  occurredAt     DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([sourceType, sourceId])
  @@index([organizationId, createdAt])
  @@index([organizationId, projectId, createdAt])
  @@index([organizationId, sourceType, createdAt])
  @@index([projectId, createdAt])
}

model ProjectReport {
  id             String              @id @default(cuid())
  organizationId String
  projectId      String
  type           ProjectReportType
  status         ProjectReportStatus @default(PENDING)
  title          String
  content        Json?
  markdown       String?
  pdfStorageKey  String?
  contentHash    String?
  periodStart    DateTime?
  periodEnd      DateTime?
  generatedAt    DateTime?
  errorMessage   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([projectId, type, status, createdAt])
  @@index([status, createdAt])
}

model ProjectState {
  id                          String             @id @default(cuid())
  organizationId              String
  projectId                   String             @unique
  health                      ProjectStateHealth @default(UNKNOWN)
  completionPercent           Int                @default(0)
  lastActivityAt              DateTime?
  lastWhatsAppUpdateAt        DateTime?
  lastEvidenceAt              DateTime?
  lastReportAt                DateTime?
  openActionItemCount         Int                @default(0)
  urgentActionItemCount       Int                @default(0)
  highPriorityActionItemCount Int                @default(0)
  nextMilestone               String?
  nextMilestoneDate           DateTime?
  completedMilestonesCount    Int                @default(0)
  delayedMilestonesCount      Int                @default(0)
  upcomingMilestonesCount     Int                @default(0)
  recentProgressSummary       String?
  recentRiskSummary           String?
  recentEvidenceSummary       String?
  recentBlockerSummary        String?
  pendingDecisionSummary      String?
  metadata                    Json?
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt
  organization                Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project                     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId, health, updatedAt])
  @@index([organizationId, lastActivityAt])
}

model Recommendation {
  id                    String                   @id @default(cuid())
  organizationId        String
  projectId             String
  type                  RecommendationType
  title                 String
  description           String
  reason                String
  confidence            RecommendationConfidence
  priority              RecommendationPriority   @default(MEDIUM)
  status                RecommendationStatus     @default(PENDING)
  sourceCoordinator     CoordinatorType
  sourceEntityType      String?
  sourceEntityId        String?
  proposedActionType    RecommendationActionType
  proposedActionPayload Json?
  approvedAt            DateTime?
  approvedByUserId      String?
  dismissedAt           DateTime?
  dismissedByUserId     String?
  dismissReason         String?
  completedAt           DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  approvedByUser        User?                    @relation("RecommendationApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  dismissedByUser       User?                    @relation("RecommendationDismissedBy", fields: [dismissedByUserId], references: [id], onDelete: SetNull)
  organization          Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project               Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  whatsAppDrafts        WhatsAppDraft[]
  milestones            Milestone[]

  @@index([organizationId, status, priority, createdAt])
  @@index([projectId, status, priority, createdAt])
  @@index([sourceCoordinator, proposedActionType, sourceEntityId])
  @@index([approvedByUserId])
  @@index([dismissedByUserId])
}

model CoordinatorRun {
  id                     String               @id @default(cuid())
  organizationId         String
  projectId              String
  coordinatorType        CoordinatorType
  status                 CoordinatorRunStatus @default(STARTED)
  startedAt              DateTime             @default(now())
  finishedAt             DateTime?
  recommendationsCreated Int                  @default(0)
  error                  String?
  metadata               Json?
  organization           Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project                Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId, startedAt])
  @@index([projectId, startedAt])
  @@index([coordinatorType, status, startedAt])
}

model WhatsAppDraft {
  id                String              @id @default(cuid())
  organizationId    String
  projectId         String
  whatsappAccountId String?
  conversationId    String?
  recommendationId  String?
  messageBody       String
  status            WhatsAppDraftStatus @default(DRAFT)
  createdByUserId   String?
  approvedByUserId  String?
  sentAt            DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  approvedByUser    User?               @relation("WhatsAppDraftApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  conversation      Conversation?       @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  createdByUser     User?               @relation("WhatsAppDraftCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recommendation    Recommendation?     @relation(fields: [recommendationId], references: [id], onDelete: SetNull)
  whatsappAccount   WhatsAppAccount?    @relation(fields: [whatsappAccountId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt])
  @@index([projectId, status, createdAt])
  @@index([recommendationId])
  @@index([conversationId])
  @@index([whatsappAccountId])
  @@index([createdByUserId])
  @@index([approvedByUserId])
}

model UserFeedback {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  type           FeedbackType
  message        String
  page           String?
  status         String       @default("OPEN")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model ProductAnalyticsEvent {
  id             String        @id @default(cuid())
  organizationId String?
  userId         String?
  eventName      String
  metadata       Json?
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, eventName, createdAt])
  @@index([userId, createdAt])
  @@index([eventName, createdAt])
}

model UserNotification {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  type           String
  title          String
  body           String?
  href           String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, createdAt])
  @@index([userId, readAt, createdAt])
}

model ProcessingJob {
  id             String              @id @default(cuid())
  organizationId String
  projectId      String?
  type           ProcessingJobType
  status         ProcessingJobStatus @default(PENDING)
  sourceType     String
  sourceId       String
  attempts       Int                 @default(0)
  maxAttempts    Int                 @default(3)
  errorMessage   String?
  correlationId  String
  nextRunAt      DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([type, sourceType, sourceId])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, type, status])
  @@index([projectId, status, createdAt])
  @@index([status, createdAt])
  @@index([status, nextRunAt, createdAt])
}

model WorkerHeartbeat {
  id              String       @id @default(cuid())
  workerName      String       @unique
  version         String
  status          WorkerStatus @default(STARTING)
  lastHeartbeatAt DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status, lastHeartbeatAt])
}

model WhatsAppAccount {
  id                    String                @id @default(cuid())
  organizationId        String
  displayName           String
  phoneNumber           String?
  connectorType         WhatsAppConnectorType @default(BAILEYS)
  status                WhatsAppAccountStatus @default(PENDING_QR)
  sessionKey            String
  lastConnectedAt       DateTime?
  lastDisconnectedAt    DateTime?
  disconnectedAt        DateTime?
  disconnectAlertSentAt DateTime?
  recoveryAlertSentAt   DateTime?
  lastDisconnectReason  String?
  lastMessageAt         DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  chatMappings          WhatsAppChatMapping[]
  drafts                WhatsAppDraft[]
  organization          Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([sessionKey])
  @@index([organizationId])
}

model WhatsAppChatMapping {
  id                String                    @id @default(cuid())
  organizationId    String
  whatsappAccountId String
  conversationId    String?
  projectId         String?
  jid               String
  chatName          String?
  isGroup           Boolean                   @default(false)
  status            WhatsAppChatMappingStatus @default(DISCOVERED)
  activatedAt       DateTime?
  activatedByUserId String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  activatedByUser   User?                     @relation(fields: [activatedByUserId], references: [id], onDelete: SetNull)
  conversation      Conversation?             @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  organization      Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project?                  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  whatsappAccount   WhatsAppAccount           @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)

  @@unique([whatsappAccountId, jid])
  @@unique([conversationId])
  @@index([activatedByUserId])
  @@index([organizationId])
  @@index([projectId])
  @@index([status])
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum Channel {
  WHATSAPP
  EMAIL
  SLACK
  TEAMS
  SMS
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  VOICE
  VIDEO
  SYSTEM
}

