generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                  String                @id @default(cuid())
  name                String
  slug                String                @unique
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  aiMessageClassifications AIMessageClassification[]
  conversations       Conversation[]
  memberships         Membership[]
  projects            Project[]
  suggestedTasks      SuggestedTask[]
  whatsAppAccounts    WhatsAppAccount[]
  whatsAppChatMapping WhatsAppChatMapping[]
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  activatedWhatsAppChatMappings WhatsAppChatMapping[]
  acceptedSuggestedTasks SuggestedTask[] @relation("SuggestedTaskAcceptedBy")
  memberships  Membership[]
  rejectedSuggestedTasks SuggestedTask[] @relation("SuggestedTaskRejectedBy")
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(MEMBER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Project {
  id                  String                @id @default(cuid())
  organizationId      String
  name                String
  code                String
  status              ProjectStatus         @default(ACTIVE)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  aiMessageClassifications AIMessageClassification[]
  conversations       Conversation[]
  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  suggestedTasks      SuggestedTask[]
  whatsAppChatMapping WhatsAppChatMapping[]

  @@index([organizationId])
  @@unique([organizationId, code])
}

model Conversation {
  id             String        @id @default(cuid())
  organizationId String
  projectId      String?
  externalId     String
  channel        Channel
  title          String
  isGroup        Boolean       @default(false)
  lastMessageAt  DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  attachments    Attachment[]
  messages       Message[]
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  participants   Participant[]
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  whatsAppMapping WhatsAppChatMapping?

  @@index([organizationId, updatedAt])
  @@index([projectId])
  @@unique([organizationId, channel, externalId])
}

model Participant {
  id                 String       @id @default(cuid())
  conversationId     String
  displayName        String
  externalIdentifier String
  role               String
  createdAt          DateTime     @default(now())
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentMessages       Message[]

  @@index([conversationId])
  @@unique([conversationId, externalIdentifier])
}

model Message {
  id                  String           @id @default(cuid())
  conversationId      String
  senderParticipantId String
  direction           MessageDirection
  type                MessageType
  body                String?
  externalMessageId   String?
  occurredAt          DateTime
  createdAt           DateTime         @default(now())
  aiClassification     AIMessageClassification?
  attachments         Attachment[]
  conversation        Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderParticipant   Participant      @relation(fields: [senderParticipantId], references: [id], onDelete: Restrict)
  suggestedTasks       SuggestedTask[]

  @@index([conversationId, occurredAt])
  @@index([senderParticipantId])
  @@unique([conversationId, externalMessageId])
}

model Attachment {
  id             String       @id @default(cuid())
  messageId      String
  conversationId String
  filename       String
  mimeType       String
  storageKey     String
  size           Int
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([messageId])
}

model AIMessageClassification {
  id                       String                 @id @default(cuid())
  organizationId           String
  projectId                String?
  messageId                String                 @unique
  category                 AIMessageCategory?
  summary                  String?
  location                 String?
  priority                 AIPriority             @default(MEDIUM)
  suggestedTaskTitle       String?
  suggestedTaskDescription String?
  shouldCreateTask         Boolean                @default(false)
  confidence               Float?
  reasoningSummary         String?
  rawModelOutput           Json?
  status                   AIClassificationStatus @default(PENDING)
  errorMessage             String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  message                  Message                @relation(fields: [messageId], references: [id], onDelete: Cascade)
  organization             Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project                  Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  suggestedTasks           SuggestedTask[]

  @@index([organizationId, createdAt])
  @@index([projectId, createdAt])
  @@index([status, createdAt])
}

model SuggestedTask {
  id               String              @id @default(cuid())
  organizationId   String
  projectId        String
  messageId        String
  classificationId String
  title            String
  description      String?
  priority         AIPriority
  status           SuggestedTaskStatus @default(PENDING)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  acceptedAt       DateTime?
  acceptedByUserId String?
  rejectedAt       DateTime?
  rejectedByUserId String?
  acceptedByUser   User?               @relation("SuggestedTaskAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  classification   AIMessageClassification @relation(fields: [classificationId], references: [id], onDelete: Cascade)
  message          Message             @relation(fields: [messageId], references: [id], onDelete: Cascade)
  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rejectedByUser   User?               @relation("SuggestedTaskRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt])
  @@index([projectId, status, createdAt])
  @@index([messageId])
  @@index([classificationId])
  @@index([acceptedByUserId])
  @@index([rejectedByUserId])
}

model WhatsAppAccount {
  id                 String                 @id @default(cuid())
  organizationId     String
  displayName        String
  phoneNumber        String?
  connectorType      WhatsAppConnectorType  @default(BAILEYS)
  status             WhatsAppAccountStatus  @default(PENDING_QR)
  sessionKey         String
  lastConnectedAt    DateTime?
  lastDisconnectedAt DateTime?
  lastMessageAt      DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  chatMappings       WhatsAppChatMapping[]
  organization       Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@unique([sessionKey])
}

model WhatsAppChatMapping {
  id                String          @id @default(cuid())
  organizationId    String
  whatsappAccountId String
  conversationId    String?
  projectId         String?
  jid               String
  chatName          String?
  isGroup           Boolean         @default(false)
  status            WhatsAppChatMappingStatus @default(DISCOVERED)
  activatedAt       DateTime?
  activatedByUserId String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  activatedByUser   User?           @relation(fields: [activatedByUserId], references: [id], onDelete: SetNull)
  conversation      Conversation?   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project           Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  whatsappAccount   WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)

  @@index([activatedByUserId])
  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@unique([whatsappAccountId, jid])
  @@unique([conversationId])
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum Channel {
  WHATSAPP
  EMAIL
  SLACK
  TEAMS
  SMS
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  VOICE
  VIDEO
  SYSTEM
}

enum WhatsAppConnectorType {
  BAILEYS
  META_CLOUD
}

enum WhatsAppAccountStatus {
  PENDING_QR
  CONNECTING
  CONNECTED
  DISCONNECTED
  ERROR
}

enum WhatsAppChatMappingStatus {
  DISCOVERED
  ACTIVE
  IGNORED
  ARCHIVED
}

enum AIMessageCategory {
  PROGRESS_UPDATE
  DEFECT
  DELAY
  SAFETY_ISSUE
  DELIVERY
  INSPECTION_REQUEST
  CLIENT_APPROVAL
  VARIATION_ORDER
  RFI
  MATERIAL_ISSUE
  MANPOWER_ISSUE
  GENERAL_NOTE
  UNKNOWN
}

enum AIPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AIClassificationStatus {
  PENDING
  COMPLETED
  FAILED
  NEEDS_REVIEW
}

enum SuggestedTaskStatus {
  PENDING
  ACCEPTED
  REJECTED
  CONVERTED
}
