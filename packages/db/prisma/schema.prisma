generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
  memberships   Membership[]
  projects      Project[]
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  Membership[]
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(MEMBER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Project {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  code           String
  status         ProjectStatus  @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  conversations  Conversation[]
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@unique([organizationId, code])
}

model Conversation {
  id             String        @id @default(cuid())
  organizationId String
  projectId      String?
  externalId     String
  channel        Channel
  title          String
  isGroup        Boolean       @default(false)
  lastMessageAt  DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  attachments    Attachment[]
  messages       Message[]
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  participants   Participant[]
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId, updatedAt])
  @@index([projectId])
  @@unique([organizationId, channel, externalId])
}

model Participant {
  id                 String       @id @default(cuid())
  conversationId     String
  displayName        String
  externalIdentifier String
  role               String
  createdAt          DateTime     @default(now())
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentMessages       Message[]

  @@index([conversationId])
  @@unique([conversationId, externalIdentifier])
}

model Message {
  id                  String           @id @default(cuid())
  conversationId      String
  senderParticipantId String
  direction           MessageDirection
  type                MessageType
  body                String?
  externalMessageId   String?
  occurredAt          DateTime
  createdAt           DateTime         @default(now())
  attachments         Attachment[]
  conversation        Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderParticipant   Participant      @relation(fields: [senderParticipantId], references: [id], onDelete: Restrict)

  @@index([conversationId, occurredAt])
  @@index([senderParticipantId])
  @@unique([conversationId, externalMessageId])
}

model Attachment {
  id             String       @id @default(cuid())
  messageId      String
  conversationId String
  filename       String
  mimeType       String
  storageKey     String
  size           Int
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([messageId])
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum Channel {
  WHATSAPP
  EMAIL
  SLACK
  TEAMS
  SMS
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  VOICE
  VIDEO
  SYSTEM
}
